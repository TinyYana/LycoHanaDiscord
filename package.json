{
  "name": "lycohana-bot",
  "version": "0.0.0",
  "private": true,
  "type": "commonjs",
  "description": "彼岸花 Discord Bot v3.0 — community operations core.",
  "author": "TinyYana",
  "license": "SEE LICENSE IN LICENSE",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --noEmit",
    "dev": "pnpm --filter @lycohana/bot dev",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "pnpm --filter @lycohana/db db:generate",
    "db:migrate": "pnpm --filter @lycohana/db db:migrate"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.20.0"
  }
}
