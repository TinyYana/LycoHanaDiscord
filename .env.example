# --- Discord ---
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
# Optional: register slash commands to a single guild during development.
DISCORD_GUILD_ID=

# --- Database ---
# Dev substitute for PostgreSQL: SQLite file path.
DATABASE_URL=./data/lycohana.db

# --- Runtime ---
NODE_ENV=development
LOG_LEVEL=info

# --- Activity tunables (optional; domain defaults apply if unset) ---
# ACTIVITY_TIME_ZONE=Asia/Taipei
# ACTIVITY_CHAT_COOLDOWN_MS=60000
# ACTIVITY_VOICE_DAILY_CAP_SECONDS=14400
# ACTIVITY_INTERACTION_DAILY_CAP=20
# ACTIVE_MEMBER_WINDOW_DAYS=30
