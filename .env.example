# --- Discord ---
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
# Optional: register slash commands to a single guild during development.
DISCORD_GUILD_ID=

# --- Database ---
# PostgreSQL connection string (Supabase). Find it in Supabase:
# Project Settings → Database → Connection string (URI). SSL is required.
# Direct connection uses port 5432; the transaction pooler uses 6543.
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# --- Runtime ---
NODE_ENV=development
LOG_LEVEL=info

# --- Activity tunables (optional; domain defaults apply if unset) ---
# ACTIVITY_TIME_ZONE=Asia/Taipei
# ACTIVITY_CHAT_COOLDOWN_MS=60000
# ACTIVITY_VOICE_DAILY_CAP_SECONDS=14400
# ACTIVITY_INTERACTION_DAILY_CAP=20
# ACTIVITY_IMAGE_DAILY_CAP=10
# ACTIVITY_MUSIC_DAILY_CAP=10
# ACTIVE_MEMBER_WINDOW_DAYS=30
# ACTIVE_MEMBER_CRON=0 4 * * *
# EMBED_DRAFT_TTL_MINUTES=60

# --- Moderation tunables (optional; domain defaults apply if unset) ---
# Default honeypot timeout when a channel sets no per-channel duration.
# HONEYPOT_TIMEOUT_SECONDS=600
